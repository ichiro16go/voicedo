# --- Public (Expoのアプリ側で参照可) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_SENTRY_DSN=

# Google Sign-In (docs/auth-setup.md 参照)
# - Web Client ID: Supabase の signInWithIdToken の audience として必須
# - iOS Client ID: iOS bundleId と紐付け
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# --- Server-only (API route / Edge Function) ---
# 絶対にEXPO_PUBLIC_を付けない（クライアントに露出する）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
REVENUECAT_SECRET_KEY=

# --- Local dev ---
NODE_ENV=development
